# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/underground_id

# JWT
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRE=7d

# OpenAI
OPENAI_API_KEY=sk-...

# Google Cloud (for voice)
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_CLOUD_KEY_PATH=./google-key.json

# Socket.io
SOCKET_ORIGINS=http://localhost:3000,http://localhost:19000
