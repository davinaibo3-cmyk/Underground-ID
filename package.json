{
  "name": "underground-id",
  "version": "2.0.0",
  "description": "Underground ID - AI ChatGPT Platform with Voice Commands (Production Ready)",
  "main": "backend/src/index.js",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "start": "npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend/mobile && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install && npm install --workspace backend && npm install --workspace frontend/mobile",
    "test": "npm run test:backend",
    "test:backend": "cd backend && npm test",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend/mobile && npm run build",
    "docker:build": "docker build -t underground-id:2.0.0 .",
    "docker:run": "docker run -p 5000:5000 underground-id:2.0.0",
    "docker:compose": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "lint": "eslint backend/src/**/*.js",
    "format": "prettier --write \"backend/src/**/*.js\"",
    "db:migrate": "node backend/scripts/migrate.js",
    "db:seed": "node backend/scripts/seed.js"
  },
  "keywords": ["ai", "chatgpt", "voice", "multilingual", "realtime", "production"],
  "author": "davinaibo3-cmyk",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.1",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3"
  }
}
